# 环境变量示例文件
# 复制此文件为 .env.local 并填写实际值

# 数据库配置（后续版本使用）
# DATABASE_URL="postgresql://user:password@localhost:5432/clearcut"
# DIRECT_URL="postgresql://user:password@localhost:5432/clearcut"

# 认证配置（后续版本使用）
# NEXTAUTH_SECRET="your-secret-key-here"
# NEXTAUTH_URL="http://localhost:3000"

# Remove.bg API
REMOVE_BG_API_KEY="your-removebg-api-key"

# 存储配置（Cloudflare）
CLOUDFLARE_ACCOUNT_ID="your-account-id"
CLOUDFLARE_API_TOKEN="your-api-token"
CLOUDFLARE_R2_BUCKET="clearcut-images"

# 支付配置（后续版本使用）
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# 邮件配置（后续版本使用）
# EMAIL_SERVER="smtp://user:pass@smtp.example.com:587"
# EMAIL_FROM="noreply@clearcut.com"

# 监控配置
SENTRY_DSN="https://..."

# 网站分析
NEXT_PUBLIC_PLAUSIBLE_DOMAIN="clearcut.app"

# 应用配置
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="ClearCut"
NEXT_PUBLIC_APP_DESCRIPTION="智能图片背景移除工具"